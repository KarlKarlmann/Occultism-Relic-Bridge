// Spezifische Einstellungen für diese Mod
group = 'net.occultism_relics_bridge'
// Die Version wird hier separat für DIESE Mod definiert
version = '1.0.1'

minecraft {
    // Hier definieren wir nur die Mixins und den Mod-Source für die Run-Configs.
    runs {
        client {
            arg "-mixin.config=occultism_relics_bridge.mixins.json"
            mods { "occultism_relics_bridge" { source sourceSets.main } }
        }
        server {
            arg "-mixin.config=occultism_relics_bridge.mixins.json"
            mods { "occultism_relics_bridge" { source sourceSets.main } }
        }
    }
}

// Mixin-Setup für diese spezifische Mod
mixin {
    add sourceSets.main, "occultism_relics_bridge.refmap.json"
    config "occultism_relics_bridge.mixins.json"
}

// Expliziter Repositories-Block
repositories {
    flatDir {
        // Sucht im 'libs' Ordner des ÜBERGEORDNETEN Projekts
        dirs rootProject.file('libs')
    }
    maven { url = "https://cursemaven.com" } 
}

dependencies {
    // Annotation Processor für die Mixins
    annotationProcessor 'org.spongepowered:mixin:0.8.5:processor'

    // Die Abhängigkeiten dieser Mod
    implementation name: "occultism-${occultism_version}"
    implementation name: "relics-${relics_version}"
}

// WICHTIG: Ersetzt Variablen wie ${version} in der mods.toml während des Builds
processResources {
    def expandProps = [
        "version": project.version
    ]
    
    inputs.properties(expandProps)
    
    filesMatching(['META-INF/mods.toml', 'pack.mcmeta']) {
        expand expandProps
    }
}

jar {
    // HIER legen wir den exakten Dateinamen fest!
    // Resultat z.B.: occultism_relics_bridge_by_KarlKarlmann_Forge_1.20.1_ver_1.0.0.jar
    archiveFileName = "${project.name}_by_KarlKarlmann_Forge_${mc_version}_ver_${project.version}.jar"
    
    manifest {
        attributes([
            "Specification-Title": "Occultism Relics Bridge",
            "Specification-Vendor": "KarlKarlmann",
            "Specification-Version": "1",
            "Implementation-Title": project.name,
            "Implementation-Version": project.version,
            "Implementation-Vendor": "KarlKarlmann",
            "Implementation-Timestamp": new Date().format("yyyy-MM-dd'T'HH:mm:ssZ"),
            "MixinConfigs": "occultism_relics_bridge.mixins.json"
        ])
    }
}